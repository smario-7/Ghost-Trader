# Automatyczna normalizacja zakończeń linii
* text=auto

# Python
*.py text eol=lf
*.pyi text eol=lf

# Shell scripts
*.sh text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# JSON
*.json text eol=lf

# Markdown
*.md text eol=lf

# Docker
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Git
.gitignore text eol=lf
.gitattributes text eol=lf

# Binarne pliki
*.db binary
*.sqlite binary
*.sqlite3 binary
*.pkl binary
*.pickle binary

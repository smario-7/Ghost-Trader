# ===========================================
# TRADING BOT - ZMIENNE ŚRODOWISKOWE
# ===========================================

# ----- TELEGRAM BOT -----
# Token bota z @BotFather (wymagane)
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ID czatu do wysyłki powiadomień (wymagane)
# Pobierz z: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=123456789

# ----- BAZA DANYCH -----
# Ścieżka do pliku SQLite
DATABASE_PATH=/app/data/trading_bot.db

# ----- API SECURITY -----
# Klucz API do zabezpieczenia endpointów (wymagane)
# Wygeneruj: openssl rand -hex 32
API_KEY=twoj_bezpieczny_klucz_api_tutaj

# ----- OPENAI API (opcjonalne) -----
# Klucz API OpenAI dla funkcji AI (analiza makro, sentiment)
# Pobierz z: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Model OpenAI (gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-4, gpt-3.5-turbo)
OPENAI_MODEL=gpt-4o

# ----- APLIKACJA -----
# Środowisko uruchomieniowe
ENVIRONMENT=production

# Host i port
API_HOST=0.0.0.0
API_PORT=8000

# Interwał sprawdzania sygnałów (w minutach)
CHECK_INTERVAL=15

# ----- LOGOWANIE -----
# Poziom logów: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Ścieżka do pliku logów
LOG_FILE=/app/data/logs/bot.log

# ----- BACKUP -----
# Katalog backupów
BACKUP_DIR=/app/data/backups

# Automatyczny backup (true/false)
AUTO_BACKUP=true

# Częstotliwość backupu (w godzinach)
BACKUP_INTERVAL=24

# ----- RATE LIMITING -----
# Maksymalna liczba requestów na minutę
RATE_LIMIT_PER_MINUTE=60

# ----- CORS -----
# Dozwolone origins (oddzielone przecinkiem)
CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# ----- MONITORING -----
# Webhook do healthcheck (opcjonalnie)
HEALTH_CHECK_URL=

# Interwał healthcheck (w sekundach)
HEALTH_CHECK_INTERVAL=300

# ----- AUTOMATYCZNE ANALIZY AI (ETAP 4) -----
# Interwał automatycznych analiz AI (w minutach)
ANALYSIS_INTERVAL=30

# Czy automatyczne analizy AI są włączone (true/false)
ANALYSIS_ENABLED=true

# Maksymalna liczba symboli do analizy
ANALYSIS_SYMBOLS_LIMIT=10

# Timeout dla pojedynczej analizy (w sekundach)
ANALYSIS_TIMEOUT=60

# Pauza między analizami symboli (w sekundach)
ANALYSIS_PAUSE_BETWEEN_SYMBOLS=2

# ----- SIGNAL AGGREGATOR - WAGI ŹRÓDEŁ ANALIZ (ETAP 7) -----
# System głosowania większościowego - wagi dla różnych źródeł analiz
# WAŻNE: Suma wszystkich wag MUSI wynosić dokładnie 100, inaczej aplikacja nie wystartuje!
#
# Przykład działania:
#   AI=40, Technical=30, Macro=20, News=10 → suma=100 ✅
#   Jeśli 3 z 4 źródeł wskazuje BUY → agreement_score=75%
#
# Waga dla AI Analysis (analiza OpenAI GPT)
AGGREGATOR_WEIGHT_AI=40

# Waga dla Technical Indicators (RSI, MACD, MA, Bollinger)
AGGREGATOR_WEIGHT_TECHNICAL=30

# Waga dla Macro Data (dane makroekonomiczne: Fed, inflacja, PKB)
AGGREGATOR_WEIGHT_MACRO=20

# Waga dla News Sentiment (analiza sentymentu wiadomości)
AGGREGATOR_WEIGHT_NEWS=10

# ----- POWIADOMIENIA TELEGRAM -----
# Minimalny próg zgodności (agreement_score) do wysłania powiadomienia Telegram
# Wartość 0-100 (%). Powiadomienie wysyłane tylko gdy agreement_score >= tego progu
#
# Przykład:
#   NOTIFICATION_THRESHOLD=60 → powiadomienie gdy ≥60% źródeł się zgadza
#   NOTIFICATION_THRESHOLD=75 → tylko bardzo pewne sygnały (konserwatywne)
#
# Rekomendacja: 60-75% dla balansu między jakością a ilością sygnałów
NOTIFICATION_THRESHOLD=60
